---
import { readFileSync } from 'node:fs';
import { parse } from 'yaml';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Gallery from '../components/Gallery.astro';
import Lightbox from '../components/Lightbox.astro';

// Load paintings data at build time
const yamlContent = readFileSync('src/content/paintings.yaml', 'utf-8');
const paintings = parse(yamlContent) as Array<{
  id: string;
  custom_id: number;
  sort_id: number;
  title: string;
  year: number | null;
  width_cm: number;
  height_cm: number;
  technique: string;
  status: number;
  tags: string[];
  published: boolean;
}>;

// Filter out unpublished paintings
const publishedPaintings = paintings.filter((p) => p.published !== false);
---

<Base title="F. Luchino — La Galleria">
  <Header currentPath={Astro.url.pathname} />
  <Gallery paintings={publishedPaintings} />
  <Lightbox />
</Base>
