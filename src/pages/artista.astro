---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';

const base = import.meta.env.BASE_URL;
---

<Base title="F. Luchino — L'Artista">
  <Header currentPath={Astro.url.pathname} />
  <main class="artista">
    <header class="artista__hero">
      <h1 class="artista__title">L'Artista</h1>
      <div class="artista__hero-rule" aria-hidden="true"></div>
    </header>

    <div class="artista__content">
      <div class="artista__portrait">
        <img
          src={`${base}/assets/francesco-luchino.svg`}
          alt="Francesco Luchino"
          class="artista__image"
          loading="eager"
        />
      </div>

      <div class="artista__text">
        <p>Tenterò di esporre in breve i fini che si propone di raggiungere la mia pittura. Essa è ed intende rimanere, pur nelle sue possibili variazioni, essenzialmente figurativa, e servendosi dei mezzi espressivi propri della pittura (linea, forma, colore) mira ad ottenere la rievocazione a livello qualitativo della realtà visibile, sia che nel contenuto di tale realtà prevalga l'aspetto plastico - coloristico (il cosiddetto paesaggio) sia che prevalga l'aspetto storico realistico (vicenda umana).</p>
        <p class="artista__attribution">— Francesco Luchino</p>
      </div>
    </div>
  </main>
</Base>

<script>
  // Scroll-reveal for content
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
  );

  document.querySelectorAll('.artista__portrait, .artista__text').forEach((el, i) => {
    el.style.transitionDelay = `${i * 0.15}s`;
    observer.observe(el);
  });
</script>
