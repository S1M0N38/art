---
interface Props {
  id: string;
  title: string;
  year: number | null;
  width_cm: number;
  height_cm: number;
  technique: string;
  status: number;
  tags: string[];
  back_photo: string | null;
}

const { id, title, year, width_cm, height_cm, technique, status, tags, back_photo } = Astro.props;

import { imageUrl } from "../utils/images";

const hasBack = !!back_photo;

const thumbUrl = imageUrl("front/thumbs", `${id}.webp`);
const placeholderUrl = imageUrl("front/placeholders", `${id}.webp`);
const originalUrl = imageUrl("front/original", `${id}.jpg`);
const backThumbUrl = hasBack ? imageUrl("back/thumbs", `${id}.webp`) : '';
const backPlaceholderUrl = hasBack ? imageUrl("back/placeholders", `${id}.webp`) : '';
const backOriginalUrl = hasBack ? imageUrl("back/original", `${id}.jpg`) : '';
const aspect = width_cm / height_cm;
---

<div
  class="painting-card"
  data-id={id}
  data-title={title}
  data-year={year ?? ''}
  data-width={width_cm}
  data-height={height_cm}
  data-technique={technique}
  data-status={status}
  data-tags={tags.join(',')}
  data-thumb={thumbUrl}
  data-full={originalUrl}
  data-has-back={hasBack ? 'true' : 'false'}
  data-back-thumb={backThumbUrl}
  data-back-full={backOriginalUrl}
  style={`--aspect: ${aspect.toFixed(4)};`}
>
  <div class="painting-card__wrap">
    <img
      src={placeholderUrl}
      data-src={thumbUrl}
      alt={title}
      width={width_cm}
      height={height_cm}
      class="painting-card__img painting-card__img--placeholder"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="painting-card__overlay">
    <div class="painting-card__title">{title}</div>
    <div class="painting-card__dims">{width_cm} × {height_cm} cm</div>
  </div>
</div>
