---
interface Props {
  id: string;
  title: string;
  year: number | null;
  width_cm: number;
  height_cm: number;
  technique: string;
  tags: string[];
}

const { id, title, year, width_cm, height_cm, technique, tags } = Astro.props;

const base = `${import.meta.env.BASE_URL}/images`;
const thumbUrl = `${base}/thumbs/${id}.webp`;
const placeholderUrl = `${base}/placeholders/${id}.webp`;
const originalUrl = `${base}/originals/${id}.jpg`;
const aspect = width_cm / height_cm;
---

<div
  class="painting-card"
  data-id={id}
  data-title={title}
  data-year={year ?? ''}
  data-width={width_cm}
  data-height={height_cm}
  data-technique={technique}
  data-tags={tags.join(',')}
  data-thumb={thumbUrl}
  data-full={originalUrl}
  style={`--aspect: ${aspect.toFixed(4)};`}
>
  <div class="painting-card__wrap">
    <img
      src={placeholderUrl}
      data-src={thumbUrl}
      alt={title}
      width={width_cm}
      height={height_cm}
      class="painting-card__img painting-card__img--placeholder"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="painting-card__overlay">
    <div class="painting-card__title">{title}</div>
    <div class="painting-card__dims">{width_cm} × {height_cm} cm</div>
  </div>
</div>
