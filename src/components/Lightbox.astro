---
// Lightbox.astro — PhotoSwipe v5 wrapper.
// Renders nothing server-side; all logic is in the client script.
---

<script src="../scripts/lightbox.js"></script>

<style is:global>
  /* White background + dark icons — overrides photoswipe/style.css */
  .pswp {
    --pswp-bg: #fff;
    --pswp-icon-color: #1a1a1a;
    --pswp-icon-color-secondary: #888;
    --pswp-placeholder-bg: #f5f3ef;
  }

  .pswp.pswp--light-bg {
    --pswp-bg: #fff;
    --pswp-icon-color: #1a1a1a;
    --pswp-icon-color-secondary: #888;
    --pswp-placeholder-bg: #f5f3ef;
  }

  /* Direct bg element override for reliability */
  .pswp--light-bg .pswp__bg {
    background: #fff;
  }

  /* Remove icon outline shadow (designed for dark bg, not needed on white) */
  .pswp__icn-shadow {
    display: none;
  }

  /* Counter text — clean, no shadow */
  .pswp .pswp__counter {
    color: #1a1a1a;
    text-shadow: none !important;
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }

  /* Flip button — inherit black icon color like other buttons */
  .pswp__button--flip {
    color: var(--pswp-icon-color);
  }
  .pswp__button--flip .pswp__icn {
    color: var(--pswp-icon-color);
  }

  /* Flip button active state */
  .pswp__button--flip-active {
    color: var(--color-accent);
  }
  .pswp__button--flip-active .pswp__icn {
    color: var(--color-accent);
    stroke: var(--color-accent);
  }
</style>
